{"html":"<!DOCTYPE html>\n<html lang=\"en-AU\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n\n<!-- ============================================================\n     SEO  (per-tenant: title / description / canonical are tokens)\n     ============================================================ -->\n<title>Mortgage Broker Canberra | {{businessName}} — Home Loans &amp; Refinancing</title>\n<meta name=\"description\" content=\"Canberra mortgage broker comparing 30+ lenders to find your sharpest home loan rate. Free borrowing assessment, no fee to you. Buying, refinancing or investing in the ACT.\">\n<link rel=\"canonical\" href=\"https://{{domain}}/\">\n<meta name=\"robots\" content=\"index,follow\">\n\n<!-- Open Graph -->\n<meta property=\"og:type\" content=\"website\">\n<meta property=\"og:title\" content=\"{{businessName}} — Canberra Mortgage Broker\">\n<meta property=\"og:description\" content=\"Compare 30+ lenders and see your real repayments in seconds. Free borrowing assessment for ACT buyers, refinancers and investors.\">\n<meta property=\"og:url\" content=\"https://{{domain}}/\">\n<meta property=\"og:locale\" content=\"en_AU\">\n\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n\n<!-- ============================================================\n     Structured data — LocalBusiness + FAQ (helps the local pack)\n     ============================================================ -->\n<script type=\"application/ld+json\">\n{\n  \"@context\": \"https://schema.org\",\n  \"@type\": \"FinancialService\",\n  \"name\": \"{{businessName}}\",\n  \"image\": \"https://{{domain}}/og.jpg\",\n  \"url\": \"https://{{domain}}/\",\n  \"telephone\": \"{{phone}}\",\n  \"priceRange\": \"Free to you — lender paid\",\n  \"areaServed\": \"Canberra & the ACT\",\n  \"address\": {\n    \"@type\": \"PostalAddress\",\n    \"addressLocality\": \"Canberra\",\n    \"addressRegion\": \"ACT\",\n    \"addressCountry\": \"AU\"\n  },\n  \"geo\": { \"@type\": \"GeoCoordinates\", \"latitude\": -35.2809, \"longitude\": 149.1300 },\n  \"aggregateRating\": { \"@type\": \"AggregateRating\", \"ratingValue\": \"4.9\", \"reviewCount\": \"87\" }\n}\n</script>\n<script type=\"application/ld+json\">\n{\n  \"@context\": \"https://schema.org\",\n  \"@type\": \"FAQPage\",\n  \"mainEntity\": [\n    { \"@type\": \"Question\", \"name\": \"Does it cost me anything to use a broker?\",\n      \"acceptedAnswer\": { \"@type\": \"Answer\", \"text\": \"No. In almost all cases the lender pays the broker, so our service is free to you. We tell you up front if a product ever charges a fee.\" } },\n    { \"@type\": \"Question\", \"name\": \"How many lenders do you compare?\",\n      \"acceptedAnswer\": { \"@type\": \"Answer\", \"text\": \"We compare home loans from more than 30 banks and lenders across Australia and match the structure to your situation, not just the lowest headline rate.\" } },\n    { \"@type\": \"Question\", \"name\": \"Can you help if I'm self-employed?\",\n      \"acceptedAnswer\": { \"@type\": \"Answer\", \"text\": \"Yes. Self-employed and PAYG borrowers both welcome — we know which lenders take a sensible view of business income and how to present it.\" } }\n  ]\n}\n</script>\n\n<style>\n/* ============================================================\n   DESIGN TOKENS — \"eucalypt & brass\" broker theme\n   These map directly to the platform's theme system.\n   ============================================================ */\n:root{\n  --ink:#14201d;          /* near-black, green-tinted text */\n  --forest:#1b3a34;       /* primary — deep eucalypt */\n  --forest-700:#16302b;\n  --sage:#6b8f7b;         /* mid green */\n  --sage-soft:#e4ece6;    /* tint surface */\n  --paper:#f6f4ef;        /* cool paper background */\n  --card:#ffffff;\n  --brass:#c9a227;        /* accent — numbers / highlights */\n  --brass-deep:#9c7d14;   /* accent for text on light */\n  --line:rgba(20,32,29,.12);\n  --line-strong:rgba(20,32,29,.22);\n  --ok:#2f7d5b;\n  --shadow:0 1px 2px rgba(20,32,29,.06),0 8px 30px rgba(20,32,29,.08);\n  --radius:14px;\n  --maxw:1140px;\n}\n*{box-sizing:border-box}\nhtml{scroll-behavior:smooth}\nbody{\n  margin:0;background:var(--paper);color:var(--ink);\n  font-family:\"Inter\",system-ui,-apple-system,sans-serif;\n  font-size:17px;line-height:1.6;-webkit-font-smoothing:antialiased;\n}\nh1,h2,h3{font-family:\"Fraunces\",Georgia,serif;font-weight:600;line-height:1.08;margin:0;letter-spacing:-.01em}\np{margin:0}\na{color:inherit}\n.wrap{max-width:var(--maxw);margin:0 auto;padding:0 24px}\n.eyebrow{font-family:\"Inter\";font-weight:600;font-size:13px;letter-spacing:.14em;text-transform:uppercase;color:var(--brass-deep)}\n\n/* buttons */\n.btn{display:inline-flex;align-items:center;gap:.5em;border:0;cursor:pointer;\n  font-family:\"Inter\";font-weight:600;font-size:16px;border-radius:999px;\n  padding:14px 26px;text-decoration:none;transition:transform .15s ease,box-shadow .15s ease,background .15s}\n.btn:active{transform:translateY(1px)}\n.btn-primary{background:var(--forest);color:#fff}\n.btn-primary:hover{background:var(--forest-700);box-shadow:var(--shadow)}\n.btn-ghost{background:transparent;color:var(--forest);border:1.5px solid var(--line-strong)}\n.btn-ghost:hover{border-color:var(--forest)}\n.btn-brass{background:var(--brass);color:var(--ink)}\n.btn-brass:hover{filter:brightness(1.04);box-shadow:var(--shadow)}\n\n/* ---------- header ---------- */\nheader.site{position:sticky;top:0;z-index:50;background:rgba(246,244,239,.86);\n  backdrop-filter:blur(10px);border-bottom:1px solid var(--line)}\n.bar{display:flex;align-items:center;justify-content:space-between;height:68px}\n.brand{display:flex;align-items:center;gap:11px;font-family:\"Fraunces\";font-weight:600;font-size:21px;letter-spacing:-.02em;text-decoration:none}\n.brand .mark{width:34px;height:34px;border-radius:9px;background:var(--forest);position:relative;flex:none}\n.brand .mark::after{content:\"\";position:absolute;inset:9px 8px;border:2px solid var(--brass);border-bottom:0;border-radius:3px 3px 0 0}\n.nav-actions{display:flex;align-items:center;gap:18px}\n.phone-link{font-weight:600;text-decoration:none;white-space:nowrap}\n.phone-link span{color:var(--sage);font-weight:500}\n@media(max-width:760px){.phone-link{display:none}}\n\n/* ---------- hero ---------- */\n.hero{padding:62px 0 30px}\n.hero-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:54px;align-items:center}\n.hero h1{font-size:clamp(38px,5vw,62px)}\n.hero h1 em{font-style:italic;color:var(--brass-deep)}\n.hero-sub{margin-top:22px;font-size:19px;color:#3a4a45;max-width:34ch}\n.hero-cta{margin-top:30px;display:flex;gap:14px;flex-wrap:wrap}\n.trust-row{margin-top:30px;display:flex;gap:22px;flex-wrap:wrap;align-items:center;font-size:14px;color:#46544f}\n.trust-row b{font-family:\"Fraunces\";font-size:22px;color:var(--forest);font-weight:600}\n.stars{color:var(--brass);letter-spacing:2px}\n@media(max-width:880px){\n  .hero-grid{grid-template-columns:1fr;gap:34px}\n  .hero{padding:34px 0 8px}\n}\n\n/* ---------- calculator (the signature element) ---------- */\n.calc{background:var(--forest);color:#eef3f0;border-radius:20px;padding:26px 26px 30px;\n  box-shadow:0 18px 50px rgba(20,32,29,.22);position:relative;overflow:hidden}\n.calc::before{content:\"\";position:absolute;top:-40px;right:-40px;width:180px;height:180px;\n  border:1px solid rgba(201,162,39,.25);border-radius:50%}\n.calc h3{color:#fff;font-size:15px;font-family:\"Inter\";font-weight:600;letter-spacing:.04em;text-transform:uppercase;opacity:.85}\n.readout{margin:6px 0 20px}\n.readout .label{font-size:13px;opacity:.75;letter-spacing:.03em}\n.readout .amount{font-family:\"Fraunces\";font-weight:600;font-size:clamp(42px,7vw,58px);color:var(--brass);\n  line-height:1;letter-spacing:-.02em;font-variant-numeric:tabular-nums}\n.readout .freq{font-size:15px;opacity:.8;margin-left:4px;font-family:\"Inter\"}\n.field{margin-bottom:16px}\n.field-top{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:7px}\n.field label{font-size:13.5px;opacity:.85}\n.field .val{font-family:\"Inter\";font-weight:600;font-variant-numeric:tabular-nums;font-size:15px;color:#fff}\ninput[type=range]{-webkit-appearance:none;appearance:none;width:100%;height:5px;border-radius:3px;\n  background:rgba(255,255,255,.18);outline:none}\ninput[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:20px;height:20px;border-radius:50%;\n  background:var(--brass);cursor:pointer;border:3px solid var(--forest);box-shadow:0 0 0 1px var(--brass)}\ninput[type=range]::-moz-range-thumb{width:18px;height:18px;border-radius:50%;background:var(--brass);\n  cursor:pointer;border:3px solid var(--forest)}\n.freq-toggle{display:flex;gap:6px;background:rgba(255,255,255,.1);border-radius:10px;padding:4px;margin-top:4px}\n.freq-toggle button{flex:1;border:0;background:transparent;color:#dfe8e3;font-family:\"Inter\";font-weight:600;\n  font-size:13.5px;padding:8px;border-radius:7px;cursor:pointer;transition:.15s}\n.freq-toggle button.on{background:var(--brass);color:var(--ink)}\n.calc-stats{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-top:20px;\n  padding-top:18px;border-top:1px solid rgba(255,255,255,.14)}\n.calc-stats .s .k{font-size:11.5px;opacity:.7;letter-spacing:.04em;text-transform:uppercase}\n.calc-stats .s .v{font-family:\"Inter\";font-weight:600;font-size:17px;margin-top:3px;font-variant-numeric:tabular-nums}\n.lvr-note{font-size:12.5px;margin-top:14px;opacity:.85;display:flex;gap:7px;align-items:flex-start}\n.lvr-note .dot{width:8px;height:8px;border-radius:50%;background:var(--brass);margin-top:6px;flex:none}\n.calc-foot{margin-top:18px}\n.calc-foot .btn{width:100%;justify-content:center}\n.rate-tag{font-size:12px;opacity:.7;text-align:center;margin-top:11px}\n\n/* ---------- generic section ---------- */\n.section{padding:70px 0}\n.section-head{max-width:60ch}\n.section-head h2{font-size:clamp(28px,3.4vw,42px);margin-top:12px}\n.section-head p{margin-top:14px;color:#46544f;font-size:18px}\n\n/* value cards */\n.values{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;margin-top:42px}\n.vcard{background:var(--card);border:1px solid var(--line);border-radius:var(--radius);padding:26px 22px}\n.vcard .ic{width:42px;height:42px;border-radius:11px;background:var(--sage-soft);display:grid;place-items:center;margin-bottom:16px;color:var(--forest)}\n.vcard h3{font-size:19px;font-family:\"Fraunces\"}\n.vcard p{margin-top:9px;font-size:15px;color:#4a584f}\n@media(max-width:900px){.values{grid-template-columns:1fr 1fr}}\n@media(max-width:560px){.values{grid-template-columns:1fr}}\n\n/* steps — genuine sequence, numbering earns its place */\n.steps{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:42px;counter-reset:step}\n.step{position:relative;padding-top:18px;border-top:2px solid var(--forest)}\n.step::before{counter-increment:step;content:\"0\" counter(step);font-family:\"Fraunces\";font-weight:600;\n  font-size:15px;color:var(--brass-deep);position:absolute;top:-12px;background:var(--paper);padding-right:10px}\n.step h3{font-size:21px;margin-top:6px}\n.step p{margin-top:8px;color:#4a584f;font-size:15.5px}\n@media(max-width:760px){.steps{grid-template-columns:1fr;gap:26px}}\n\n/* lenders strip */\n.lenders{background:var(--forest);color:#e9f0ec}\n.lenders .wrap{padding:46px 24px;text-align:center}\n.lenders h2{color:#fff;font-size:clamp(24px,3vw,34px)}\n.lender-logos{display:flex;flex-wrap:wrap;gap:14px 30px;justify-content:center;margin-top:26px;\n  font-family:\"Fraunces\";font-weight:600;font-size:20px;opacity:.78}\n\n/* testimonial */\n.quote-wrap{display:grid;grid-template-columns:1fr 1fr;gap:46px;align-items:center}\n.bigquote{font-family:\"Fraunces\";font-weight:500;font-size:clamp(24px,3vw,33px);line-height:1.25;letter-spacing:-.01em}\n.bigquote .stars{display:block;font-size:18px;margin-bottom:18px}\n.byline{margin-top:22px;font-size:15px;color:#4a584f}\n.byline b{color:var(--ink)}\n@media(max-width:760px){.quote-wrap{grid-template-columns:1fr;gap:24px}}\n\n/* lead form */\n.lead{background:var(--sage-soft)}\n.lead-grid{display:grid;grid-template-columns:1fr 1.05fr;gap:50px;align-items:start}\n.lead-grid h2{font-size:clamp(28px,3.4vw,40px)}\n.lead-points{margin-top:24px;display:grid;gap:14px}\n.lead-points li{list-style:none;display:flex;gap:12px;align-items:flex-start;font-size:16px;color:#3c4a44}\n.lead-points .tick{width:22px;height:22px;border-radius:50%;background:var(--forest);color:#fff;display:grid;place-items:center;flex:none;font-size:12px;margin-top:2px}\n.form-card{background:var(--card);border-radius:18px;padding:30px;box-shadow:var(--shadow);border:1px solid var(--line)}\n.form-row{display:grid;grid-template-columns:1fr 1fr;gap:14px}\n.ff{margin-bottom:14px}\n.ff label{display:block;font-size:13.5px;font-weight:600;margin-bottom:6px}\n.ff input,.ff select{width:100%;padding:13px 14px;border:1.5px solid var(--line-strong);border-radius:10px;\n  font-family:\"Inter\";font-size:15.5px;background:#fff;color:var(--ink)}\n.ff input:focus,.ff select:focus{outline:none;border-color:var(--forest);box-shadow:0 0 0 3px rgba(27,58,52,.12)}\n.form-card .btn{width:100%;justify-content:center;margin-top:6px}\n.form-fine{font-size:12.5px;color:#6a766f;margin-top:14px;text-align:center}\n.form-success{display:none;text-align:center;padding:30px 10px}\n.form-success.show{display:block}\n.form-success .big{font-family:\"Fraunces\";font-size:26px;color:var(--forest)}\n@media(max-width:860px){.lead-grid{grid-template-columns:1fr;gap:30px}.form-row{grid-template-columns:1fr}}\n\n/* faq */\n.faq{max-width:780px;margin:42px auto 0}\n.faq details{border-bottom:1px solid var(--line);padding:18px 0}\n.faq summary{cursor:pointer;font-family:\"Fraunces\";font-weight:600;font-size:20px;list-style:none;\n  display:flex;justify-content:space-between;gap:20px;align-items:center}\n.faq summary::-webkit-details-marker{display:none}\n.faq summary::after{content:\"+\";color:var(--brass-deep);font-family:\"Inter\";font-size:24px;transition:.2s}\n.faq details[open] summary::after{transform:rotate(45deg)}\n.faq details p{margin-top:12px;color:#4a584f;font-size:16px}\n\n/* footer */\nfooter.site{background:var(--ink);color:#b9c4bf;font-size:14.5px;padding:54px 0 30px}\n.foot-grid{display:grid;grid-template-columns:2fr 1fr 1fr;gap:34px}\nfooter .brand{color:#fff}\nfooter h4{color:#fff;font-family:\"Inter\";font-size:14px;letter-spacing:.05em;text-transform:uppercase;margin:0 0 14px}\nfooter a{display:block;text-decoration:none;margin-bottom:9px;color:#b9c4bf}\nfooter a:hover{color:#fff}\n.foot-legal{margin-top:38px;padding-top:22px;border-top:1px solid rgba(255,255,255,.12);font-size:12.5px;color:#8b9893;line-height:1.7}\n@media(max-width:760px){.foot-grid{grid-template-columns:1fr;gap:26px}}\n\n/* a11y / motion */\n:focus-visible{outline:3px solid var(--brass);outline-offset:2px;border-radius:4px}\n@media(prefers-reduced-motion:reduce){*{scroll-behavior:auto!important;transition:none!important}}\n</style>\n<style id=\"lp-hp-css\">.lp-hp{position:absolute!important;left:-10000px!important;top:auto!important;width:1px!important;height:1px!important;overflow:hidden!important;opacity:0!important;pointer-events:none!important}</style>\n</head>\n<body>\n<a class=\"lpa-skip\" href=\"#top\">Skip to content</a>\n\n<!-- ============================================================\n     SITE_CONFIG — the only block that changes per tenant.\n     In the platform this is the row from `sites` + rates override.\n     ============================================================ -->\n<script>\nconst SITE_CONFIG = __SITE_CONFIG__;\n</script>\n\n<header class=\"site\">\n  <div class=\"wrap bar\">\n    <a class=\"brand\" href=\"#top\"><span class=\"mark\"></span>{{businessName}}</a>\n    <div class=\"nav-actions\">\n      <a class=\"phone-link\" id=\"navPhone\" href=\"#\"><span>Talk to a broker</span><br>{{phoneText}}</a>\n      <a class=\"btn btn-primary\" href=\"#assessment\">Free assessment</a>\n    </div>\n  </div>\n</header>\n\n<main id=\"top\">\n\n  <!-- HERO with the live calculator as the thesis -->\n  <section class=\"hero\">\n    <div class=\"wrap hero-grid\">\n      <div>\n        <span class=\"eyebrow\">Canberra mortgage broker</span>\n        <h1>See your real repayment <em>before</em> you talk to a bank.</h1>\n        <p class=\"hero-sub\">We compare more than 30 lenders to find the loan that actually fits you — then do the paperwork. No fee to you.</p>\n        <div class=\"hero-cta\">\n          <a class=\"btn btn-primary\" href=\"#assessment\">Get my free assessment</a>\n          <a class=\"btn btn-ghost\" id=\"heroCall\" href=\"#\">Call {{phoneText}}</a>\n        </div>\n        <div class=\"trust-row\">\n          <div><span class=\"stars\">★★★★★</span> <b>4.9</b> from 87 reviews</div>\n          <div><b>30+</b> lenders compared</div>\n          <div><b>$0</b> cost to you</div>\n        </div>\n      </div>\n\n      <!-- ===== Calculator instrument ===== -->\n      <div class=\"calc\" id=\"calc\" aria-label=\"Home loan repayment calculator\">\n        <h3>Repayment calculator</h3>\n        <div class=\"readout\">\n          <div class=\"label\">Estimated repayment</div>\n          <div><span class=\"amount\" id=\"rOut\">$0</span><span class=\"freq\" id=\"rFreq\">/ month</span></div>\n        </div>\n\n        <div class=\"field\">\n          <div class=\"field-top\"><label for=\"price\">Property price</label><span class=\"val\" id=\"priceV\">$750,000</span></div>\n          <input type=\"range\" id=\"price\" min=\"200000\" max=\"2500000\" step=\"10000\" value=\"750000\">\n        </div>\n        <div class=\"field\">\n          <div class=\"field-top\"><label for=\"deposit\">Deposit</label><span class=\"val\" id=\"depositV\">$150,000</span></div>\n          <input type=\"range\" id=\"deposit\" min=\"0\" max=\"800000\" step=\"5000\" value=\"150000\">\n        </div>\n        <div class=\"field\">\n          <div class=\"field-top\"><label for=\"rate\">Interest rate</label><span class=\"val\" id=\"rateV\">6.04% p.a.</span></div>\n          <input type=\"range\" id=\"rate\" min=\"3\" max=\"9\" step=\"0.01\" value=\"6.04\">\n        </div>\n        <div class=\"field\">\n          <div class=\"field-top\"><label for=\"term\">Loan term</label><span class=\"val\" id=\"termV\">30 years</span></div>\n          <input type=\"range\" id=\"term\" min=\"10\" max=\"30\" step=\"1\" value=\"30\">\n        </div>\n\n        <div class=\"freq-toggle\" role=\"group\" aria-label=\"Repayment frequency\">\n          <button type=\"button\" data-f=\"weekly\">Weekly</button>\n          <button type=\"button\" data-f=\"fortnightly\">Fortnightly</button>\n          <button type=\"button\" data-f=\"monthly\" class=\"on\">Monthly</button>\n        </div>\n\n        <div class=\"calc-stats\">\n          <div class=\"s\"><div class=\"k\">Loan amount</div><div class=\"v\" id=\"loanV\">$600,000</div></div>\n          <div class=\"s\"><div class=\"k\">LVR</div><div class=\"v\" id=\"lvrV\">80%</div></div>\n          <div class=\"s\"><div class=\"k\">Total interest</div><div class=\"v\" id=\"intV\">$0</div></div>\n        </div>\n\n        <div class=\"lvr-note\" id=\"lmiNote\" style=\"display:none\">\n          <span class=\"dot\"></span><span>Your deposit is under 20%, so Lenders Mortgage Insurance may apply. We'll show you how to structure around it.</span>\n        </div>\n\n        <div class=\"calc-foot\">\n          <a class=\"btn btn-brass\" href=\"#assessment\">Get this rate checked free →</a>\n        </div>\n        <div class=\"rate-tag\" id=\"rateTag\">Based on a 6.04% p.a. variable · comparison 6.18% p.a.</div>\n      </div>\n    </div>\n  </section>\n\n  <!-- VALUE -->\n  <section class=\"section\">\n    <div class=\"wrap\">\n      <div class=\"section-head\">\n        <span class=\"eyebrow\">Why a broker</span>\n        <h2>The bank shows you one rate. We show you the market.</h2>\n        <p>A loan officer can only sell you their own product. We sit on your side of the table and shop the whole panel.</p>\n      </div>\n      <div class=\"values\">\n        <div class=\"vcard\"><div class=\"ic\">◷</div><h3>Faster yes</h3><p>We match you to lenders likely to approve your situation, so you skip the knock-backs that dent your credit file.</p></div>\n        <div class=\"vcard\"><div class=\"ic\">⚖</div><h3>Whole-of-market</h3><p>Big four, mutuals, and specialist lenders — over 30 in total, compared on rate, fees and how they assess you.</p></div>\n        <div class=\"vcard\"><div class=\"ic\">$</div><h3>No fee to you</h3><p>The lender pays us when your loan settles. Our advice costs you nothing, and we say so up front if anything ever does.</p></div>\n        <div class=\"vcard\"><div class=\"ic\">⌂</div><h3>Local to the ACT</h3><p>We know Canberra's market, the government employee lending quirks, and the suburbs lenders treat cautiously.</p></div>\n      </div>\n    </div>\n  </section>\n\n  <!-- STEPS -->\n  <section class=\"section\" style=\"padding-top:0\">\n    <div class=\"wrap\">\n      <div class=\"section-head\"><span class=\"eyebrow\">How it works</span><h2>Three steps, mostly done by us.</h2></div>\n      <div class=\"steps\">\n        <div class=\"step\"><h3>Tell us your situation</h3><p>A 15-minute chat — income, deposit, what you're buying. Use the assessment form and we'll call you back.</p></div>\n        <div class=\"step\"><h3>We compare &amp; recommend</h3><p>We bring you the loans that fit, explain the trade-offs in plain English, and you pick the one you're happy with.</p></div>\n        <div class=\"step\"><h3>We handle settlement</h3><p>Application, lender chasing, paperwork — we run it through to settlement and stay on for future rate reviews.</p></div>\n      </div>\n    </div>\n  </section>\n\n  <!-- LENDERS -->\n  <section class=\"lenders\">\n    <div class=\"wrap\">\n      <h2>Compared across the lenders that matter</h2>\n      <div class=\"lender-logos\">\n        <span>CommBank</span><span>NAB</span><span>Westpac</span><span>ANZ</span><span>Macquarie</span><span>ING</span><span>Bankwest</span><span>Suncorp</span>\n      </div>\n    </div>\n  </section>\n\n  <!-- TESTIMONIAL -->\n  <section class=\"section\">\n    <div class=\"wrap quote-wrap\">\n      <div>\n        <span class=\"eyebrow\">A recent settlement</span>\n        <h2 style=\"margin-top:12px\">Real people, real keys.</h2>\n        <p class=\"byline\" style=\"margin-top:14px\">We refinanced 41 Canberra households last year. Most started exactly where you are now — unsure whether their current rate was still fair.</p>\n      </div>\n      <div>\n        <blockquote class=\"bigquote\">\n          <span class=\"stars\">★★★★★</span>\n          \"Did the whole refinance for us while we were juggling two kids and full-time jobs. Saved us $340 a month and we barely lifted a finger.\"\n        </blockquote>\n        <p class=\"byline\"><b>Priya &amp; Tom</b> — refinanced, Gungahlin</p>\n      </div>\n    </div>\n  </section>\n\n  <!-- LEAD FORM -->\n  <section class=\"section lead\" id=\"assessment\">\n    <div class=\"wrap lead-grid\">\n      <div>\n        <span class=\"eyebrow\">Free borrowing assessment</span>\n        <h2>Find out what you can borrow — and at what rate.</h2>\n        <ul class=\"lead-points\">\n          <li><span class=\"tick\">✓</span><span>A clear borrowing figure and the sharpest rate we can find for your situation.</span></li>\n          <li><span class=\"tick\">✓</span><span>No obligation, no credit check at this stage, no cost.</span></li>\n          <li><span class=\"tick\">✓</span><span>A real broker calls you back — usually the same business day.</span></li>\n        </ul>\n      </div>\n\n      <div class=\"form-card\">\n        <div id=\"leadForm\">\n          <div class=\"lp-hp\" aria-hidden=\"true\"><label for=\"lp_hp\">Company website</label><input type=\"text\" id=\"lp_hp\" name=\"lp_hp\" value=\"\" tabindex=\"-1\" autocomplete=\"off\"></div>\n          <div class=\"form-row\">\n            <div class=\"ff\"><label for=\"fname\">First name</label><input id=\"fname\" type=\"text\" autocomplete=\"given-name\" required></div>\n            <div class=\"ff\"><label for=\"lname\">Last name</label><input id=\"lname\" type=\"text\" autocomplete=\"family-name\" required></div>\n          </div>\n          <div class=\"form-row\">\n            <div class=\"ff\"><label for=\"email\">Email</label><input id=\"email\" type=\"email\" autocomplete=\"email\" required></div>\n            <div class=\"ff\"><label for=\"phone\">Phone</label><input id=\"phone\" type=\"tel\" autocomplete=\"tel\" required></div>\n          </div>\n          <div class=\"ff\">\n            <label for=\"goal\">What are you looking to do?</label>\n            <select id=\"goal\">\n              <option>Buy my first home</option>\n              <option>Buy my next home</option>\n              <option>Refinance an existing loan</option>\n              <option>Buy an investment property</option>\n            </select>\n          </div>\n          <button class=\"btn btn-primary\" type=\"button\" onclick=\"submitLead()\">Request my free assessment</button>\n          <p class=\"form-fine\">By submitting you agree to be contacted about your enquiry. Your details are never sold.</p>\n        </div>\n        <div class=\"form-success\" id=\"leadSuccess\">\n          <div class=\"big\">Thanks — you're booked in. ✓</div>\n          <p style=\"margin-top:10px;color:#4a584f\">A {{businessName}} broker will call you on the number you gave us, usually within a few hours during business days.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- FAQ -->\n  <section class=\"section\" style=\"padding-top:0\">\n    <div class=\"wrap\">\n      <div class=\"section-head\" style=\"margin:0 auto;text-align:center\"><span class=\"eyebrow\">Questions</span><h2>The things people ask first.</h2></div>\n      <div class=\"faq\">\n        <details open><summary>Does it cost me anything?</summary><p>No. In almost every case the lender pays the broker when your loan settles, so our service is free to you. If a product ever carries a fee, we tell you before you commit to anything.</p></details>\n        <details><summary>How many lenders do you actually compare?</summary><p>More than 30 — the big four, plus mutuals and specialist lenders. We match the structure to your situation rather than chasing the lowest headline rate, which often hides fees.</p></details>\n        <details><summary>I'm self-employed. Can you still help?</summary><p>Yes. We know which lenders take a sensible view of business and self-employed income, and how to present your numbers so you're assessed fairly.</p></details>\n        <details><summary>Is my current rate still any good?</summary><p>Probably worth a look. Lenders keep their best rates for new customers, so existing borrowers quietly drift onto higher ones. A free review tells you in minutes whether you're overpaying.</p></details>\n      </div>\n    </div>\n  </section>\n\n</main>\n\n<footer class=\"site\">\n  <div class=\"wrap\">\n    <div class=\"foot-grid\">\n      <div>\n        <a class=\"brand\" href=\"#top\"><span class=\"mark\"></span>{{businessName}}</a>\n        <p style=\"margin-top:14px;max-width:34ch\">Canberra mortgage broking. We compare the market, structure the loan, and stay on for the life of it.</p>\n      </div>\n      <div>\n        <h4>Contact</h4>\n        <a id=\"footPhone\" href=\"#\">{{phoneText}}</a>\n        <a href=\"mailto:{{email}}\">{{email}}</a>\n        <a href=\"#\">Canberra, ACT</a>\n      </div>\n      <div>\n        <h4>Services</h4>\n        <a href=\"#assessment\">First home loans</a>\n        <a href=\"#assessment\">Refinancing</a>\n        <a href=\"#assessment\">Investment loans</a>\n        <a href=\"#calc\">Repayment calculator</a>\n      </div>\n    </div>\n    <p class=\"foot-legal\">\n      Calculator results are estimates only and assume principal &amp; interest repayments at the rate shown; they are not a quote or an offer of credit. Your borrowing power and rate depend on a full assessment of your circumstances. {{businessName}} — Australian Credit Licence 000000 (placeholder). Lending criteria, fees, terms and conditions apply. © 2026 {{businessName}}.\n    </p>\n  </div>\n</footer>\n\n<script>\n/* ============================================================\n   ANALYTICS HOOKS — drop-in for the platform events table.\n   trackEvent() currently logs + pushes to dataLayer; later it\n   POSTs to /api/events keyed to site_id + page_id.\n   ============================================================ */\nwindow.dataLayer = window.dataLayer || [];\nfunction trackEvent(name, props = {}) {\n  const payload = { event: name, site: SITE_CONFIG.business, ts: Date.now(), ...props };\n  window.dataLayer.push(payload);\n  console.log(\"[track]\", payload);\n  fetch('/api/events', {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify({ site: SITE_CONFIG.business, event: name, props: { ...props, ts: Date.now() } }),\n    keepalive: true            // lets call_click fire even as the tel: link navigates away\n  }).catch(() => {});          // analytics must never block the user\n}\n\n/* ---- click-to-call: wire every tel link + log the click ---- */\n\nfunction applyVisitorAppearance(C){\n  C=C||{}; var va=C.visitorAppearance||{}, de=document.documentElement;\n  if(!va||typeof va!=='object') return;\n  var st=va.siteTheme||'classic-light';\n  if(!st||st==='classic-light'||st==='match-brand') de.removeAttribute('data-lp-site-theme');\n  else de.setAttribute('data-lp-site-theme', st);\n  var stored=null;\n  try{ stored=JSON.parse(localStorage.getItem('leadpages_visitor_accessibility')||'null'); }catch(e){}\n  if(!stored){\n    de.dataset.lpVisitorText=(va.defaultTextSize==='large')?'large':'standard';\n    de.dataset.lpVisitorContrast=(va.defaultContrast==='high')?'high':'standard';\n    if(va.reducedMotionSupport!==false) de.dataset.lpVisitorMotion='standard';\n  }\n}\nwindow.__applyBrokerConfig=function(c){\n  c=c||SITE_CONFIG||{};\n  try{applyVisitorAppearance(c);}catch(_e){}\n};\ntry{applyVisitorAppearance(SITE_CONFIG);}catch(_e){}\n\n(function wirePhones(){\n  const tel = \"tel:\" + SITE_CONFIG.phone;\n  [\"navPhone\",\"heroCall\",\"footPhone\"].forEach(id=>{\n    const el = document.getElementById(id);\n    if(!el) return;\n    el.href = tel;\n    el.addEventListener(\"click\", ()=>trackEvent(\"call_click\",{location:id}));\n  });\n})();\n\n/* ---- lead submit stub ---- */\nasync function submitLead(){\n  const data = {\n    firstName: fname.value.trim(), lastName: lname.value.trim(),\n    email: email.value.trim(), phone: phone.value.trim(), goal: goal.value\n  };\n  if(!data.firstName || !data.email || !data.phone){\n    alert(\"Please add your name, email and phone so a broker can call you back.\");\n    return;\n  }\n  trackEvent(\"lead_submit\", { goal: data.goal });\n  try {\n    const res = await fetch('/api/leads', {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({\n        site: SITE_CONFIG.business,\n        kind: \"broker\",\n        name: (data.firstName + \" \" + data.lastName).trim(),\n        email: data.email,\n        phone: data.phone,\n        lp_hp: (document.getElementById('lp_hp')&&document.getElementById('lp_hp').value)||'',\n        _t: window.__lpFormT||Date.now(),\n        details: { goal: data.goal, firstName: data.firstName, lastName: data.lastName }\n      })\n    });\n    if(!res.ok) console.error(\"Lead save failed:\", res.status, await res.text());\n  } catch(e){ console.error(\"Lead save error:\", e); }\n  // We always thank the customer so a backend hiccup never bounces a real lead.\n  // Watch the network tab / console while testing to confirm the insert succeeds.\n  document.getElementById(\"leadForm\").style.display = \"none\";\n  document.getElementById(\"leadSuccess\").classList.add(\"show\");\n}\n\n/* ============================================================\n   CALCULATOR\n   ============================================================ */\nconst fmt  = n => \"$\" + Math.round(n).toLocaleString(\"en-AU\");\nconst fmtK = n => \"$\" + Math.round(n).toLocaleString(\"en-AU\");\nlet freq = \"monthly\";\n\nconst els = {\n  price:price, deposit:deposit, rate:rate, term:term,\n  priceV:priceV, depositV:depositV, rateV:rateV, termV:termV,\n  rOut:rOut, rFreq:rFreq, loanV:loanV, lvrV:lvrV, intV:intV, lmiNote:lmiNote, rateTag:rateTag\n};\n\n/* seed rate from SITE_CONFIG (the broker override / global rate) */\nels.rate.value = SITE_CONFIG.rates.variableRate;\nels.rateTag.textContent = `Based on a ${SITE_CONFIG.rates.variableRate}% p.a. variable · comparison ${SITE_CONFIG.rates.comparisonRate}% p.a.`;\n\nfunction calc(){\n  let price = +els.price.value;\n  let deposit = Math.min(+els.deposit.value, price); // deposit can't exceed price\n  const loan = Math.max(price - deposit, 0);\n  const annual = +els.rate.value;\n  const years = +els.term.value;\n  const r = annual/100/12;\n  const n = years*12;\n\n  const monthly = r === 0 ? loan/n : loan * r * Math.pow(1+r,n) / (Math.pow(1+r,n)-1);\n  const totalInterest = monthly*n - loan;\n\n  const perFreq = freq===\"weekly\" ? monthly*12/52 : freq===\"fortnightly\" ? monthly*12/26 : monthly;\n  const freqLabel = freq===\"weekly\" ? \"/ week\" : freq===\"fortnightly\" ? \"/ fortnight\" : \"/ month\";\n\n  const lvr = price>0 ? (loan/price*100) : 0;\n\n  els.priceV.textContent   = fmt(price);\n  els.depositV.textContent = fmt(deposit);\n  els.rateV.textContent    = annual.toFixed(2) + \"% p.a.\";\n  els.termV.textContent    = years + \" years\";\n  els.rOut.textContent     = loan===0 ? \"$0\" : fmt(perFreq);\n  els.rFreq.textContent    = freqLabel;\n  els.loanV.textContent    = fmtK(loan);\n  els.lvrV.textContent     = Math.round(lvr) + \"%\";\n  els.intV.textContent     = loan===0 ? \"$0\" : fmtK(totalInterest);\n  els.lmiNote.style.display = (lvr>80 && loan>0) ? \"flex\" : \"none\";\n}\n\n[\"price\",\"deposit\",\"rate\",\"term\"].forEach(id=>els[id].addEventListener(\"input\",calc));\ndocument.querySelectorAll(\".freq-toggle button\").forEach(b=>{\n  b.addEventListener(\"click\",()=>{\n    document.querySelectorAll(\".freq-toggle button\").forEach(x=>x.classList.remove(\"on\"));\n    b.classList.add(\"on\"); freq = b.dataset.f; calc();\n    trackEvent(\"calc_freq\", { freq });\n  });\n});\ncalc();\ntrackEvent(\"page_view\", { page: \"broker_landing\" });\n</script>\n<script>(function(){try{window.__lpFormT=window.__lpFormT||Date.now();document.addEventListener(\"focusin\",function(){window.__lpFormT=window.__lpFormT||Date.now();},true);}catch(e){}})();</script>\n</body>\n</html>\n"}