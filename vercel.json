{
  "crons": [
    {
      "path": "/api/billing/cron",
      "schedule": "0 3 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap.xml"
    },
    {
      "source": "/:slug/sitemap.xml",
      "destination": "/api/sitemap.xml?slug=:slug"
    },
    {
      "source": "/marketing-sitemap.xml",
      "destination": "/api/marketing-sitemap.xml"
    },
    {
      "source": "/manage",
      "destination": "/manage.html"
    },
    {
      "source": "/partner-dashboard",
      "destination": "/partner-dashboard.html"
    },
    {
      "source": "/partner-onboarding",
      "destination": "/partner-onboarding.html"
    },
    {
      "source": "/billing",
      "destination": "/billing.html"
    },
    {
      "source": "/tradies",
      "destination": "/api/marketing-html?file=tradies.html"
    },
    {
      "source": "/domains",
      "destination": "/api/marketing-html?file=domains.html"
    },
    {
      "source": "/showcase",
      "destination": "/api/marketing-html?file=showcase.html"
    },
    {
      "source": "/marketplace",
      "destination": "/api/marketing-html?file=marketplace.html"
    },
    {
      "source": "/marketplace/:slug",
      "destination": "/api/marketing-html?file=marketplace-feature.html"
    },
    {
      "source": "/marketplace-admin",
      "destination": "/marketplace-admin.html"
    },
    {
      "source": "/apps-admin",
      "destination": "/apps-admin.html"
    },
    {
      "source": "/start-your-business",
      "destination": "/api/marketing-html?file=start-your-business.html"
    },
    {
      "source": "/resources",
      "destination": "/api/marketing-html?file=resources.html"
    },
    {
      "source": "/resources/:slug",
      "destination": "/api/marketing-html?file=resource-:slug.html"
    },
    {
      "source": "/find-a-partner",
      "destination": "/api/marketing-html?file=find-a-partner.html"
    },
    {
      "source": "/partners",
      "destination": "/api/marketing-html?file=partners.html"
    },
    {
      "source": "/partner",
      "destination": "/api/marketing-html?file=partner.html"
    },
    {
      "source": "/partners-admin",
      "destination": "/partners-admin.html"
    },
    {
      "source": "/quote",
      "destination": "/api/marketing-html?file=quote.html"
    },
    {
      "source": "/help",
      "destination": "/api/marketing-html?file=help.html"
    },
    {
      "source": "/messages",
      "destination": "/api/marketing-html?file=messages.html"
    },
    {
      "source": "/privacy-policy",
      "destination": "/api/marketing-html?file=privacy-policy.html"
    },
    {
      "source": "/terms-of-use",
      "destination": "/api/marketing-html?file=terms-of-use.html"
    },
    {
      "source": "/instagram-data-policy",
      "destination": "/api/marketing-html?file=instagram-data-policy.html"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "^(www\\.)?leadpages\\.(webculture\\.au|com\\.au)$"
        }
      ],
      "destination": "/api/marketing-html?file=home.html"
    },
    {
      "source": "/",
      "destination": "/api/render"
    },
    {
      "source": "/s/:slug",
      "destination": "/api/render?slug=:slug"
    },
    {
      "source": "/:slug/:page",
      "destination": "/api/render?slug=:slug&page=:page"
    },
    {
      "source": "/:slug",
      "destination": "/api/render?slug=:slug"
    }
  ]
}