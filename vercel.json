{
  "redirects": [
    {
      "source": "/partner-dashboard",
      "destination": "/partner",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/billing/cron",
      "schedule": "0 3 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap.xml"
    },
    {
      "source": "/:slug/sitemap.xml",
      "destination": "/api/sitemap.xml?slug=:slug"
    },
    {
      "source": "/marketing-sitemap.xml",
      "destination": "/api/marketing-sitemap.xml"
    },
    {
      "source": "/manage",
      "destination": "/manage.html"
    },
    {
      "source": "/partner-onboarding",
      "destination": "/partner-onboarding.html"
    },
    {
      "source": "/billing",
      "destination": "/billing.html"
    },
    {
      "source": "/tradies",
      "destination": "/tradies.html"
    },
    {
      "source": "/domains",
      "destination": "/domains.html"
    },
    {
      "source": "/showcase",
      "destination": "/showcase.html"
    },
    {
      "source": "/marketplace",
      "destination": "/marketplace.html"
    },
    {
      "source": "/marketplace/:slug",
      "destination": "/marketplace-feature.html"
    },
    {
      "source": "/marketplace-admin",
      "destination": "/marketplace-admin.html"
    },
    {
      "source": "/apps-admin",
      "destination": "/apps-admin.html"
    },
    {
      "source": "/start-your-business",
      "destination": "/start-your-business.html"
    },
    {
      "source": "/resources",
      "destination": "/resources.html"
    },
    {
      "source": "/resources/:slug",
      "destination": "/resource-:slug.html"
    },
    {
      "source": "/find-a-partner",
      "destination": "/find-a-partner.html"
    },
    {
      "source": "/partners",
      "destination": "/partners.html"
    },
    {
      "source": "/partner",
      "destination": "/partner.html"
    },
    {
      "source": "/partners-admin",
      "destination": "/partners-admin.html"
    },
    {
      "source": "/quote",
      "destination": "/quote.html"
    },
    {
      "source": "/online-quote",
      "destination": "/online-quote-wizard.html"
    },
    {
      "source": "/quote-portal",
      "destination": "/quote-portal.html"
    },
    {
      "source": "/offer",
      "destination": "/offer.html"
    },
    {
      "source": "/help",
      "destination": "/help.html"
    },
    {
      "source": "/messages",
      "destination": "/messages.html"
    },
    {
      "source": "/privacy-policy",
      "destination": "/privacy-policy.html"
    },
    {
      "source": "/terms-of-use",
      "destination": "/terms-of-use.html"
    },
    {
      "source": "/instagram-data-policy",
      "destination": "/instagram-data-policy.html"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "^(www\\.)?leadpages\\.(webculture\\.au|com\\.au)$"
        }
      ],
      "destination": "/api/marketing-html?file=home.html"
    },
    {
      "source": "/",
      "destination": "/api/render"
    },
    {
      "source": "/s/:slug",
      "destination": "/api/render?slug=:slug"
    },
    {
      "source": "/:slug/:page",
      "destination": "/api/render?slug=:slug&page=:page"
    },
    {
      "source": "/:slug",
      "destination": "/api/render?slug=:slug"
    }
  ]
}
