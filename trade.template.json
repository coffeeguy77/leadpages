{"html": "<!DOCTYPE html>\n<html lang=\"en-AU\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n\n<!-- ============================================================\n     SEO  (per-tenant tokens: title / description / canonical)\n     ============================================================ -->\n<title>Blocked Drains &amp; Emergency Plumber Canberra | {{businessName}}</title>\n<meta name=\"description\" content=\"Blocked drain or burst pipe in Canberra? {{businessName}} — licensed, same-day, upfront fixed pricing. 24/7 emergency plumber across the ACT. Call now for fast help.\">\n<link rel=\"canonical\" href=\"https://{{domain}}/\">\n<meta name=\"robots\" content=\"index,follow\">\n\n<meta property=\"og:type\" content=\"website\">\n<meta property=\"og:title\" content=\"{{businessName}} — Emergency Plumber &amp; Blocked Drains, Canberra\">\n<meta property=\"og:description\" content=\"Same-day blocked drains, burst pipes and hot water repairs across the ACT. Licensed, insured, upfront pricing. Call now.\">\n<meta property=\"og:url\" content=\"https://{{domain}}/\">\n<meta property=\"og:locale\" content=\"en_AU\">\n\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600;700;800&family=Barlow:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n\n<!-- Structured data — Plumber (drives the local pack) + FAQ -->\n<script type=\"application/ld+json\">\n{\n  \"@context\":\"https://schema.org\",\n  \"@type\":\"Plumber\",\n  \"name\":\"{{businessName}}\",\n  \"image\":\"https://{{domain}}/og.jpg\",\n  \"url\":\"https://{{domain}}/\",\n  \"telephone\":\"{{phone}}\",\n  \"priceRange\":\"$$\",\n  \"areaServed\":\"Canberra & the ACT\",\n  \"openingHoursSpecification\":{\"@type\":\"OpeningHoursSpecification\",\"dayOfWeek\":[\"Monday\",\"Tuesday\",\"Wednesday\",\"Thursday\",\"Friday\",\"Saturday\",\"Sunday\"],\"opens\":\"00:00\",\"closes\":\"23:59\"},\n  \"address\":{\"@type\":\"PostalAddress\",\"addressLocality\":\"Canberra\",\"addressRegion\":\"ACT\",\"addressCountry\":\"AU\"},\n  \"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":-35.2809,\"longitude\":149.1300},\n  \"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"4.9\",\"reviewCount\":\"212\"}\n}\n</script>\n<script type=\"application/ld+json\">\n{\n  \"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\n  \"mainEntity\":[\n    {\"@type\":\"Question\",\"name\":\"Do you offer same-day service?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. For blocked drains, burst pipes and no-hot-water jobs we aim to be on site the same day, and we run a 24/7 line for genuine emergencies.\"}},\n    {\"@type\":\"Question\",\"name\":\"Will I know the price before you start?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Always. We quote a fixed price up front before any work begins, so there are no surprises when the job is done.\"}},\n    {\"@type\":\"Question\",\"name\":\"Are you licensed and insured?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes — fully licensed ACT plumbers and fully insured. Your licence and insurance details are on every invoice.\"}}\n  ]\n}\n</script>\n\n<style>\n/* ============================================================\n   DESIGN TOKENS — \"charcoal & hi-vis\" trade theme\n   ============================================================ */\n:root{\n  --steel-950:#141a24;   /* darkest */\n  --steel-900:#1a2230;   /* hero / header bg */\n  --steel-800:#243142;   /* cards on dark */\n  --pipe:#1f7bb8;        /* water / steel blue */\n  --pipe-deep:#155d8c;\n  --hivis:#ff6a1f;       /* urgent CTA orange */\n  --hivis-600:#e85c14;\n  --safety:#ffc400;      /* sparing yellow accent */\n  --light:#eef2f6;       /* page bg */\n  --ink:#1a2230;\n  --muted:#5b6878;\n  --line:#dde4ec;\n  --white:#fff;\n  --radius:12px;\n  --maxw:1140px;\n  --shadow:0 10px 34px rgba(20,26,36,.14);\n}\n*{box-sizing:border-box}\nhtml{scroll-behavior:smooth}\nbody{margin:0;background:var(--light);color:var(--ink);\n  font-family:\"Barlow\",system-ui,sans-serif;font-size:17px;line-height:1.55;-webkit-font-smoothing:antialiased}\nh1,h2,h3,.display{font-family:\"Barlow Condensed\",sans-serif;font-weight:800;line-height:.98;text-transform:uppercase;letter-spacing:.01em;margin:0}\np{margin:0}\na{color:inherit}\n.wrap{max-width:var(--maxw);margin:0 auto;padding:0 22px}\n.eyebrow{font-family:\"Barlow\";font-weight:700;font-size:13px;letter-spacing:.16em;text-transform:uppercase;color:var(--pipe)}\n\n.btn{display:inline-flex;align-items:center;justify-content:center;gap:.5em;border:0;cursor:pointer;\n  font-family:\"Barlow Condensed\";font-weight:700;text-transform:uppercase;letter-spacing:.03em;\n  font-size:19px;border-radius:10px;padding:15px 26px;text-decoration:none;transition:.15s}\n.btn:active{transform:translateY(1px)}\n.btn-call{background:var(--hivis);color:#fff;box-shadow:0 6px 18px rgba(255,106,31,.35)}\n.btn-call:hover{background:var(--hivis-600)}\n.btn-quote{background:var(--white);color:var(--ink);border:2px solid var(--line)}\n.btn-quote:hover{border-color:var(--pipe)}\n.btn-pipe{background:var(--pipe);color:#fff}\n.btn-pipe:hover{background:var(--pipe-deep)}\n\n/* emergency strip */\n.emerg{background:var(--hivis);color:#fff;text-align:center;font-family:\"Barlow\";font-weight:700;\n  font-size:14.5px;padding:9px 16px;letter-spacing:.01em}\n.emerg a{text-decoration:none;border-bottom:2px solid rgba(255,255,255,.6)}\n\n/* header */\nheader.site{position:sticky;top:0;z-index:60;background:var(--steel-900);color:#fff}\n.bar{display:flex;align-items:center;justify-content:space-between;height:70px}\n.brand{display:flex;align-items:center;gap:11px;text-decoration:none;color:#fff}\n.brand .mark{width:38px;height:38px;border-radius:9px;background:var(--pipe);display:grid;place-items:center;flex:none;\n  font-family:\"Barlow Condensed\";font-weight:800;font-size:22px;color:#fff}\n.brand .nm{font-family:\"Barlow Condensed\";font-weight:800;font-size:24px;text-transform:uppercase;letter-spacing:.02em;line-height:.9}\n.brand .nm small{display:block;font-family:\"Barlow\";font-weight:600;font-size:10.5px;letter-spacing:.18em;color:var(--safety);text-transform:uppercase}\n.head-call{display:flex;align-items:center;gap:14px}\n.head-phone{text-align:right;line-height:1.05}\n.head-phone small{display:block;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:#9fb0c2;font-weight:600}\n.head-phone b{font-family:\"Barlow Condensed\";font-weight:800;font-size:23px;color:#fff;text-decoration:none}\n@media(max-width:680px){.head-phone{display:none}}\n\n/* hero */\n.hero{background:\n  linear-gradient(180deg,rgba(20,26,36,.0),rgba(20,26,36,.55)),\n  radial-gradient(120% 120% at 80% 0%, #2b3a4f 0%, var(--steel-900) 55%, var(--steel-950) 100%);\n  color:#fff;padding:64px 0 70px;position:relative;overflow:hidden}\n.hero::after{content:\"\";position:absolute;left:0;right:0;bottom:0;height:5px;\n  background:repeating-linear-gradient(45deg,var(--safety) 0 22px,#1a2230 22px 44px);opacity:.85}\n.hero .eyebrow{color:var(--safety)}\n.hero h1{font-size:clamp(44px,7vw,84px);margin-top:12px;max-width:16ch}\n.hero h1 .hl{color:var(--hivis)}\n.hero-sub{margin-top:20px;font-size:20px;color:#cdd8e3;max-width:48ch;font-weight:500}\n.hero-cta{margin-top:30px;display:flex;gap:14px;flex-wrap:wrap}\n.badges{margin-top:34px;display:flex;gap:10px 26px;flex-wrap:wrap}\n.badge{display:flex;align-items:center;gap:9px;font-weight:600;font-size:14.5px;color:#dde6ee}\n.badge .b-ic{width:30px;height:30px;border-radius:8px;background:rgba(31,123,184,.22);color:var(--safety);\n  display:grid;place-items:center;font-size:15px;flex:none}\n/* response device */\n.resp{position:absolute;top:60px;right:max(22px,calc((100vw - var(--maxw))/2 + 22px));\n  background:var(--steel-800);border:1px solid rgba(255,255,255,.1);border-radius:16px;padding:20px 22px;text-align:center;box-shadow:var(--shadow)}\n.resp .pulse{width:11px;height:11px;border-radius:50%;background:#39d98a;margin:0 auto 10px;\n  box-shadow:0 0 0 0 rgba(57,217,138,.6);animation:pulse 2s infinite}\n@keyframes pulse{0%{box-shadow:0 0 0 0 rgba(57,217,138,.55)}70%{box-shadow:0 0 0 12px rgba(57,217,138,0)}100%{box-shadow:0 0 0 0 rgba(57,217,138,0)}}\n.resp .big{font-family:\"Barlow Condensed\";font-weight:800;font-size:40px;color:#fff;line-height:1}\n.resp .lbl{font-size:12px;letter-spacing:.1em;text-transform:uppercase;color:#9fb0c2;font-weight:600;margin-top:4px}\n@media(max-width:1040px){.resp{display:none}}\n\n/* sections */\n.section{padding:66px 0}\n.section-head{max-width:62ch}\n.section-head h2{font-size:clamp(32px,4.4vw,52px);margin-top:10px}\n.section-head p{margin-top:13px;color:var(--muted);font-size:18px;font-weight:500}\n\n/* services */\n.svcs{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:40px}\n.svc{background:var(--white);border:1px solid var(--line);border-radius:var(--radius);padding:24px;\n  transition:.15s;position:relative}\n.svc:hover{border-color:var(--pipe);transform:translateY(-3px);box-shadow:var(--shadow)}\n.svc .ic{width:48px;height:48px;border-radius:11px;background:var(--steel-900);color:var(--safety);\n  display:grid;place-items:center;font-size:22px;margin-bottom:15px}\n.svc h3{font-size:24px}\n.svc p{margin-top:8px;color:var(--muted);font-size:15.5px;font-weight:500}\n@media(max-width:860px){.svcs{grid-template-columns:1fr 1fr}}\n@media(max-width:560px){.svcs{grid-template-columns:1fr}}\n\n/* why band */\n.why{background:var(--steel-900);color:#fff}\n.why .wrap{padding:62px 22px}\n.why h2{font-size:clamp(30px,4vw,46px)}\n.why-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:22px;margin-top:38px}\n.why-item .n{font-family:\"Barlow Condensed\";font-weight:800;font-size:46px;color:var(--hivis);line-height:1}\n.why-item h3{font-size:21px;margin-top:8px}\n.why-item p{margin-top:7px;color:#bcc8d4;font-size:15px;font-weight:500}\n@media(max-width:860px){.why-grid{grid-template-columns:1fr 1fr;gap:28px}}\n\n/* area */\n.area-grid{display:grid;grid-template-columns:1fr 1fr;gap:44px;align-items:center}\n.suburbs{display:flex;flex-wrap:wrap;gap:9px;margin-top:22px}\n.suburbs span{background:var(--white);border:1px solid var(--line);border-radius:999px;padding:7px 15px;font-size:14.5px;font-weight:600;color:#3a4756}\n@media(max-width:760px){.area-grid{grid-template-columns:1fr;gap:24px}}\n\n/* reviews */\n.reviews{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:40px}\n.review{background:var(--white);border:1px solid var(--line);border-radius:var(--radius);padding:24px}\n.review .stars{color:var(--safety);letter-spacing:2px;font-size:16px}\n.review p{margin-top:12px;font-size:15.5px;font-weight:500;color:#33414f}\n.review .who{margin-top:14px;font-weight:700;font-size:14.5px}\n.review .who span{color:var(--muted);font-weight:500}\n@media(max-width:860px){.reviews{grid-template-columns:1fr}}\n\n/* quote form */\n.quote{background:linear-gradient(180deg,var(--steel-900),var(--steel-950));color:#fff}\n.quote .wrap{padding:64px 22px}\n.quote-grid{display:grid;grid-template-columns:1fr 1.02fr;gap:48px;align-items:start}\n.quote h2{font-size:clamp(32px,4.4vw,52px)}\n.quote .lead-sub{margin-top:16px;color:#cdd8e3;font-size:18px;font-weight:500;max-width:42ch}\n.q-points{margin-top:26px;display:grid;gap:13px;padding:0}\n.q-points li{list-style:none;display:flex;gap:12px;align-items:center;font-weight:600;color:#e4ebf2}\n.q-points .t{width:26px;height:26px;border-radius:7px;background:var(--hivis);display:grid;place-items:center;flex:none;font-size:13px;color:#fff}\n.qcard{background:var(--white);border-radius:16px;padding:28px;box-shadow:var(--shadow);color:var(--ink)}\n.qcard h3{font-size:26px;color:var(--ink)}\n.ff{margin-bottom:13px}.ff label{display:block;font-size:13px;font-weight:700;margin-bottom:5px;text-transform:uppercase;letter-spacing:.04em;color:#46535f}\n.ff input,.ff select,.ff textarea{width:100%;padding:13px 14px;border:2px solid var(--line);border-radius:9px;font-family:\"Barlow\";font-size:16px;color:var(--ink)}\n.ff textarea{resize:vertical;min-height:74px}\n.ff input:focus,.ff select:focus,.ff textarea:focus{outline:none;border-color:var(--pipe);box-shadow:0 0 0 3px rgba(31,123,184,.16)}\n.form-row{display:grid;grid-template-columns:1fr 1fr;gap:13px}\n.qcard .btn{width:100%;margin-top:6px}\n.q-fine{font-size:12.5px;color:var(--muted);text-align:center;margin-top:12px}\n.q-success{display:none;text-align:center;padding:26px 6px}\n.q-success.show{display:block}\n.q-success .big{font-family:\"Barlow Condensed\";font-weight:800;text-transform:uppercase;font-size:30px;color:var(--pipe)}\n@media(max-width:820px){.quote-grid{grid-template-columns:1fr;gap:28px}.form-row{grid-template-columns:1fr}}\n\n/* faq */\n.faq{max-width:760px;margin:36px auto 0}\n.faq details{background:var(--white);border:1px solid var(--line);border-radius:10px;padding:16px 20px;margin-bottom:11px}\n.faq summary{cursor:pointer;font-family:\"Barlow Condensed\";font-weight:700;text-transform:uppercase;font-size:21px;list-style:none;display:flex;justify-content:space-between;gap:16px;align-items:center}\n.faq summary::-webkit-details-marker{display:none}\n.faq summary::after{content:\"+\";color:var(--hivis);font-family:\"Barlow\";font-size:26px;line-height:1}\n.faq details[open] summary::after{content:\"–\"}\n.faq p{margin-top:11px;color:#46535f;font-weight:500;font-size:16px}\n\n/* footer */\nfooter.site{background:var(--steel-950);color:#9fb0c2;padding:52px 0 110px;font-size:14.5px}\n.foot-grid{display:grid;grid-template-columns:2fr 1fr 1fr;gap:32px}\nfooter .brand{margin-bottom:14px}\nfooter h4{color:#fff;font-family:\"Barlow Condensed\";font-weight:700;text-transform:uppercase;font-size:17px;letter-spacing:.04em;margin:0 0 12px}\nfooter a{display:block;text-decoration:none;margin-bottom:8px;color:#9fb0c2}\nfooter a:hover{color:#fff}\n.foot-legal{margin-top:34px;padding-top:20px;border-top:1px solid rgba(255,255,255,.1);font-size:12.5px;color:#6b7986;line-height:1.7}\n@media(max-width:760px){.foot-grid{grid-template-columns:1fr;gap:24px}}\n\n/* sticky mobile call bar */\n.mobile-call{position:fixed;left:0;right:0;bottom:0;z-index:70;display:none;\n  background:var(--hivis);box-shadow:0 -6px 20px rgba(20,26,36,.25)}\n.mobile-call a{display:flex;align-items:center;justify-content:center;gap:10px;color:#fff;text-decoration:none;\n  font-family:\"Barlow Condensed\";font-weight:800;text-transform:uppercase;font-size:21px;padding:15px;letter-spacing:.02em}\n@media(max-width:680px){.mobile-call{display:block}}\n\n:focus-visible{outline:3px solid var(--safety);outline-offset:2px;border-radius:5px}\n@media(prefers-reduced-motion:reduce){*{scroll-behavior:auto!important;transition:none!important;animation:none!important}}\n</style>\n</head>\n<body>\n\n<!-- ============================================================\n     SITE_CONFIG — per-tenant block (the `sites` row).\n     This single object turns the template into the next trade.\n     ============================================================ -->\n<script>\nconst SITE_CONFIG = __SITE_CONFIG__;\n(function(){\n  function esc(s){return String(s==null?'':s).replace(/[&<>]/g,function(c){return{'&':'&amp;','<':'&lt;','>':'&gt;'}[c];});}\n  function shade(hex,pct){ if(!hex||hex.charAt(0)!=='#'||hex.length<7) return hex; function cl(n){return Math.max(0,Math.min(255,Math.round(n)));} var r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16),f=pct/100; r=cl(r+(pct<0?r:255-r)*f); g=cl(g+(pct<0?g:255-g)*f); b=cl(b+(pct<0?b:255-b)*f); return '#'+[r,g,b].map(function(x){return ('0'+x.toString(16)).slice(-2);}).join(''); }\n  function applyCfg(C){\n    C=C||{}; var rs=document.documentElement.style, th=C.theme||{};\n    function setv(v,name,deep,pct){ if(v){ rs.setProperty(name,v); if(deep) rs.setProperty(deep,shade(v,pct)); } else { rs.removeProperty(name); if(deep) rs.removeProperty(deep); } }\n    setv(th.pipe,'--pipe','--pipe-deep',-22);\n    setv(th.hivis,'--hivis','--hivis-600',-12);\n    if(th.steel){ rs.setProperty('--steel-900',th.steel); rs.setProperty('--steel-950',shade(th.steel,-30)); rs.setProperty('--steel-800',shade(th.steel,18)); } else { rs.removeProperty('--steel-900'); rs.removeProperty('--steel-950'); rs.removeProperty('--steel-800'); }\n    setv(th.safety,'--safety',null,0);\n    if(Array.isArray(C.services)){ var grid=document.querySelector('.svcs'); if(grid){ var on=C.services.filter(function(s){return s&&s.on!==false&&(s.title||s.body||s.icon);}); grid.innerHTML=on.map(function(s){return '<div class=\"svc\"><div class=\"ic\">'+esc(s.icon||'')+'</div><h3>'+esc(s.title||'')+'</h3><p>'+esc(s.body||'')+'</p></div>';}).join(''); } }\n    if(C.logo){ var L=C.logo, brands=document.querySelectorAll('a.brand'); for(var i=0;i<brands.length;i++){ var a=brands[i]; if(a.__orig==null) a.__orig=a.innerHTML; if(L.mode==='image'&&L.imageUrl){ a.innerHTML='<img src=\"'+esc(L.imageUrl)+'\" alt=\"'+esc(L.text||'')+'\" style=\"max-height:40px;width:auto;display:block\">'; } else { a.innerHTML=a.__orig; var mark=a.querySelector('.mark'), nm=a.querySelector('.nm'); if(L.mode==='text'&&mark) mark.style.display='none'; if(nm&&L.text){ var sm=nm.querySelector('small'); nm.textContent=L.text; if(sm) nm.appendChild(sm); } } } }\n    var SEC=C.sections||{};\n    Object.keys(SEC).forEach(function(id){\n      var node=document.querySelector('[data-sec=\"'+id+'\"]'); if(!node) return;\n      var s=SEC[id]||{};\n      if(s.on===false){ node.style.display='none'; return; } node.style.display='';\n      if(s.eyebrow!=null){ var e=node.querySelector('.eyebrow'); if(e) e.textContent=s.eyebrow; }\n      if(id==='hero'){\n        if(s.title!=null||s.titleHl!=null){ var h1=node.querySelector('h1'); if(h1) h1.innerHTML=esc(s.title!=null?s.title:'')+(s.titleHl?' <span class=\"hl\">'+esc(s.titleHl)+'</span>':''); }\n        if(s.sub!=null){ var hs=node.querySelector('.hero-sub'); if(hs) hs.textContent=s.sub; }\n      } else {\n        if(s.heading!=null){ var h2=node.querySelector('h2'); if(h2) h2.textContent=s.heading; }\n        if(s.intro!=null){ var pp=node.querySelector('.section-head p'); if(pp) pp.textContent=s.intro; }\n      }\n    });\n      (function(){ var SEC=C.sections||{};\n      function rlist(sel,items,fn){ var box=document.querySelector(sel); if(!box||!Array.isArray(items)) return; box.innerHTML=items.filter(function(it){return it&&it.on!==false;}).map(fn).join(''); }\n      var nmEl=document.querySelector('a.brand .nm'); var BIZ=(nmEl&&nmEl.textContent.trim())||'';\n      function tok(s){ return String(s==null?'':s).replace(/\\{\\{\\s*businessName\\s*\\}\\}/g,BIZ); }\n      if(SEC.hero&&Array.isArray(SEC.hero.badges)) rlist('.badges',SEC.hero.badges,function(b){return '<div class=\"badge\"><span class=\"b-ic\">'+esc(b.icon||'')+'</span>'+esc(b.text||'')+'</div>';});\n      if(SEC.why&&Array.isArray(SEC.why.items)) rlist('.why-grid',SEC.why.items,function(w){return '<div class=\"why-item\"><div class=\"n\">'+esc(w.n||'')+'</div><h3>'+esc(w.title||'')+'</h3><p>'+esc(w.body||'')+'</p></div>';});\n      if(SEC.reviews&&Array.isArray(SEC.reviews.items)) rlist('.reviews',SEC.reviews.items,function(r){return '<div class=\"review\"><div class=\"stars\">'+esc(r.stars||'\\u2605\\u2605\\u2605\\u2605\\u2605')+'</div><p>'+esc(tok(r.text||''))+'</p><div class=\"who\">'+esc(r.who||'')+'</div></div>';});\n      if(SEC.faq&&Array.isArray(SEC.faq.items)) rlist('.faq',SEC.faq.items,function(f){return '<details><summary>'+esc(f.q||'')+'</summary><p>'+esc(f.a||'')+'</p></details>';});\n      if(SEC.area){ if(Array.isArray(SEC.area.suburbs)){ var sb=document.querySelector('.suburbs'); if(sb) sb.innerHTML=SEC.area.suburbs.filter(function(x){return x&&String(x).trim();}).map(function(x){return '<span>'+esc(String(x).trim())+'</span>';}).join(''); } if(SEC.area.intro!=null){ var an=document.querySelector('[data-sec=\"area\"]'); if(an){ var ap=an.querySelector('p'); if(ap) ap.textContent=SEC.area.intro; } } }\n    })();\n    (function(){ var S=C.sections||{};\n      var nmEl=document.querySelector('a.brand .nm'); var BIZ=(nmEl&&nmEl.textContent.trim())||'';\n      function tok(s){ return String(s==null?'':s).replace(/\\{\\{\\s*businessName\\s*\\}\\}/g,BIZ); }\n      var E=S.emerg||{}; var em=document.querySelector('.emerg'); if(em && E.text!=null){ var ea=em.querySelector('a'); em.textContent=E.text+' '; if(ea) em.appendChild(ea); }\n      var Q=S.quote||{}; var qs=document.querySelector('[data-sec=\"quote\"]'); if(qs){\n        if(Q.sub!=null){ var ls=qs.querySelector('.lead-sub'); if(ls) ls.textContent=Q.sub; }\n        if(Array.isArray(Q.points)){ var ul=qs.querySelector('.q-points'); if(ul) ul.innerHTML=Q.points.filter(function(x){return x&&x.text&&x.on!==false;}).map(function(x){return '<li><span class=\"t\">\\u2713</span>'+esc(x.text)+'</li>';}).join(''); }\n        if(Q.button!=null){ var bt=qs.querySelector('.btn-call'); if(bt) bt.textContent=Q.button; }\n      }\n      var F=S.footer||{}; var ft=document.querySelector('footer.site'); if(ft){\n        if(F.blurb!=null){ var fp=ft.querySelector('.foot-grid p'); if(fp) fp.textContent=tok(F.blurb); }\n        if(F.legal!=null){ var fl=ft.querySelector('.foot-legal'); if(fl) fl.textContent=tok(F.legal); }\n        if(Array.isArray(F.services)){ var cols=ft.querySelectorAll('.foot-grid > div'); var col=cols[cols.length-1]; if(col){ var h4=col.querySelector('h4'); var lk=F.services.filter(function(s){return s&&s.label&&s.on!==false;}); col.innerHTML=(h4?h4.outerHTML:'')+lk.map(function(s){return '<a href=\"'+esc(s.href||'#quote')+'\">'+esc(s.label)+'</a>';}).join(''); } }\n      }\n    })();\n    (function(){ var S=C.sections||{};\n      var H=S.header||{};\n      var hp=document.querySelector('.head-phone small'); if(hp&&H.cta!=null) hp.textContent=H.cta;\n      var hc=document.getElementById('headCall'); if(hc&&H.button!=null) hc.textContent=H.button;\n      var Q=S.quote||{}; var qs=document.querySelector('[data-sec=\"quote\"]');\n      if(qs){\n        if(Q.formTitle!=null){ var qh=qs.querySelector('.qcard h3'); if(qh) qh.textContent=Q.formTitle; }\n        var lmap={name:'lblName',phone:'lblPhone',job:'lblJob',suburb:'lblSuburb',detail:'lblDetail'};\n        Object.keys(lmap).forEach(function(k){ var v=Q[lmap[k]]; if(v!=null){ var lb=qs.querySelector('label[for=\"'+k+'\"]'); if(lb) lb.textContent=v; } });\n        if(Array.isArray(Q.jobOptions)){ var sel=qs.querySelector('#job'); if(sel) sel.innerHTML=Q.jobOptions.filter(function(o){return o&&o.text&&o.on!==false;}).map(function(o){return '<option>'+esc(o.text)+'</option>';}).join(''); }\n        if(Q.successTitle!=null){ var bg=qs.querySelector('.q-success .big'); if(bg) bg.textContent=Q.successTitle; }\n      }\n    })();\n}\n  window.__applyTradeConfig=applyCfg;\n  if(document.readyState==='loading') document.addEventListener('DOMContentLoaded',function(){applyCfg(SITE_CONFIG);}); else applyCfg(SITE_CONFIG);\n})();\n</script>\n\n<div class=\"emerg\" data-sec=\"emerg\">⚠ 24/7 Emergency Plumber — Burst pipe or flooding? <a id=\"emergCall\" href=\"#\">Call {{phoneText}} now</a></div>\n\n<header class=\"site\">\n  <div class=\"wrap bar\">\n    <a class=\"brand\" href=\"#top\">\n      <span class=\"mark\">{{initial}}</span>\n      <span class=\"nm\">{{businessName}}</span>\n    </a>\n    <div class=\"head-call\">\n      <div class=\"head-phone\"><small>Speak to a plumber</small><b id=\"navPhone\">{{phoneText}}</b></div>\n      <a class=\"btn btn-call\" id=\"headCall\" href=\"#\">Call now</a>\n    </div>\n  </div>\n</header>\n\n<main id=\"top\">\n\n  <!-- HERO — the phone number is the thesis -->\n  <section class=\"hero\" data-sec=\"hero\">\n    <div class=\"wrap\">\n      <span class=\"eyebrow\">Licensed Canberra plumber · Same-day</span>\n      <h1>Blocked drain? <span class=\"hl\">We'll clear it today.</span></h1>\n      <p class=\"hero-sub\">Fast, fixed-price plumbing across the ACT — blocked drains, burst pipes, hot water and leaks. You'll know the price before we start.</p>\n      <div class=\"hero-cta\">\n        <a class=\"btn btn-call\" id=\"heroCall\" href=\"#\">📞 Call {{phoneText}}</a>\n        <a class=\"btn btn-quote\" href=\"#quote\">Get a fast quote</a>\n      </div>\n      <div class=\"badges\">\n        <div class=\"badge\"><span class=\"b-ic\">✓</span>Licensed &amp; insured</div>\n        <div class=\"badge\"><span class=\"b-ic\">★</span>4.9 from 212 reviews</div>\n        <div class=\"badge\"><span class=\"b-ic\">$</span>Upfront fixed pricing</div>\n        <div class=\"badge\"><span class=\"b-ic\">⚡</span>Same-day service</div>\n      </div>\n    </div>\n    <div class=\"resp\">\n      <div class=\"pulse\"></div>\n      <div class=\"big\">~60<span style=\"font-size:20px\"> min</span></div>\n      <div class=\"lbl\">Avg response, ACT</div>\n    </div>\n  </section>\n\n  <!-- SERVICES -->\n  <section data-sec=\"services\" class=\"section\">\n    <div class=\"wrap\">\n      <div class=\"section-head\"><span class=\"eyebrow\">What we fix</span><h2>One call sorts the lot.</h2><p>From a slow kitchen sink to a flooded laundry at 2am — we handle the everyday and the emergencies.</p></div>\n      <div class=\"svcs\">\n        <div class=\"svc\"><div class=\"ic\">🚿</div><h3>Blocked Drains</h3><p>High-pressure water jetting and electric eel to clear blockages fast — kitchen, bathroom, sewer and stormwater.</p></div>\n        <div class=\"svc\"><div class=\"ic\">💧</div><h3>Burst &amp; Leaking Pipes</h3><p>Burst mains, slab leaks and dripping joints found and repaired before they wreck your floors and walls.</p></div>\n        <div class=\"svc\"><div class=\"ic\">🔥</div><h3>Hot Water Systems</h3><p>No hot water? Repairs and same-day replacement on gas, electric and heat-pump systems.</p></div>\n        <div class=\"svc\"><div class=\"ic\">📹</div><h3>CCTV Drain Camera</h3><p>We send a camera down the line to find the real problem — tree roots, cracks, collapses — and show you the footage.</p></div>\n        <div class=\"svc\"><div class=\"ic\">🔎</div><h3>Leak Detection</h3><p>Hidden leak driving up your water bill? We pinpoint it without tearing the place apart.</p></div>\n        <div class=\"svc\"><div class=\"ic\">🛠️</div><h3>General Plumbing</h3><p>Taps, toilets, gas fitting, renovations and the jobs you've been putting off. Done properly, first time.</p></div>\n      </div>\n    </div>\n  </section>\n\n  <!-- WHY -->\n  <section data-sec=\"why\" class=\"why\">\n    <div class=\"wrap\">\n      <span class=\"eyebrow\" style=\"color:var(--safety)\">Why {{businessName}}</span>\n      <h2>No call-out games. No surprise bills.</h2>\n      <div class=\"why-grid\">\n        <div class=\"why-item\"><div class=\"n\">01</div><h3>Upfront pricing</h3><p>A fixed price agreed before we start. The number we quote is the number you pay.</p></div>\n        <div class=\"why-item\"><div class=\"n\">24/7</div><h3>Real emergencies</h3><p>Burst pipe at midnight? We answer the phone and get someone moving, day or night.</p></div>\n        <div class=\"why-item\"><div class=\"n\">★</div><h3>Properly licensed</h3><p>Fully licensed ACT plumbers, fully insured. Licence details on every invoice.</p></div>\n        <div class=\"why-item\"><div class=\"n\">⌂</div><h3>Local &amp; trusted</h3><p>Canberra-based, Canberra-owned. We know the suburbs, the soil and the old pipework.</p></div>\n      </div>\n    </div>\n  </section>\n\n  <!-- SERVICE AREA -->\n  <section data-sec=\"area\" class=\"section\">\n    <div class=\"wrap area-grid\">\n      <div>\n        <span class=\"eyebrow\">Where we work</span>\n        <h2 style=\"font-size:clamp(30px,4vw,46px);margin-top:10px\">Across Canberra &amp; the ACT</h2>\n        <p style=\"margin-top:13px;color:var(--muted);font-weight:500;font-size:18px\">If you're in the ACT, we cover you. Same-day where we can, every day of the week.</p>\n        <div class=\"suburbs\">\n          <span>Gungahlin</span><span>Belconnen</span><span>Woden</span><span>Tuggeranong</span><span>Civic</span><span>Dickson</span><span>Queanbeyan</span><span>Molonglo</span><span>Weston Creek</span><span>Kingston</span>\n        </div>\n      </div>\n      <div>\n        <div class=\"qcard\" style=\"text-align:center;background:var(--steel-900);color:#fff\">\n          <h3 style=\"color:#fff;font-size:30px\">Need a plumber now?</h3>\n          <p style=\"margin:12px 0 20px;color:#cdd8e3;font-weight:500\">Talk to a real Canberra plumber — not a call centre.</p>\n          <a class=\"btn btn-call\" id=\"areaCall\" href=\"#\" style=\"font-size:24px\">📞 {{phoneText}}</a>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- REVIEWS -->\n  <section data-sec=\"reviews\" class=\"section\" style=\"padding-top:0\">\n    <div class=\"wrap\">\n      <div class=\"section-head\"><span class=\"eyebrow\">From the neighbours</span><h2>212 five-star reviews and counting.</h2></div>\n      <div class=\"reviews\">\n        <div class=\"review\"><div class=\"stars\">★★★★★</div><p>\"Blocked sewer on a Sunday, total panic. {{businessName}} had someone out within the hour and jetted it clear. Fixed price, no fuss.\"</p><div class=\"who\">Marcus T. <span>— Belconnen</span></div></div>\n        <div class=\"review\"><div class=\"stars\">★★★★★</div><p>\"Hot water died the morning we had guests. New system in and running by lunch. Couldn't fault them.\"</p><div class=\"who\">Jenny K. <span>— Woden</span></div></div>\n        <div class=\"review\"><div class=\"stars\">★★★★★</div><p>\"Used the drain camera to show me the tree root problem instead of just guessing. Honest and proper work.\"</p><div class=\"who\">Dave R. <span>— Gungahlin</span></div></div>\n      </div>\n    </div>\n  </section>\n\n  <!-- QUOTE FORM -->\n  <section data-sec=\"quote\" class=\"quote\" id=\"quote\">\n    <div class=\"wrap quote-grid\">\n      <div>\n        <span class=\"eyebrow\" style=\"color:var(--safety)\">Fast quote</span>\n        <h2>Tell us the problem.<br>We'll call you straight back.</h2>\n        <p class=\"lead-sub\">Two minutes now saves you a flooded weekend. Send the details and a plumber calls you — usually within the hour during the day.</p>\n        <ul class=\"q-points\">\n          <li><span class=\"t\">✓</span>Upfront fixed price, no call-out surprises</li>\n          <li><span class=\"t\">✓</span>Same-day where we can get to you</li>\n          <li><span class=\"t\">✓</span>Licensed, insured, local</li>\n        </ul>\n      </div>\n      <div class=\"qcard\">\n        <div id=\"quoteForm\">\n          <h3>Get my quote</h3>\n          <div class=\"form-row\" style=\"margin-top:16px\">\n            <div class=\"ff\"><label for=\"name\">Name</label><input id=\"name\" type=\"text\" autocomplete=\"name\" required></div>\n            <div class=\"ff\"><label for=\"phone\">Phone</label><input id=\"phone\" type=\"tel\" autocomplete=\"tel\" required></div>\n          </div>\n          <div class=\"ff\">\n            <label for=\"job\">What's the problem?</label>\n            <select id=\"job\">\n              <option>Blocked drain</option><option>Burst or leaking pipe</option><option>No hot water</option>\n              <option>Hidden leak / high water bill</option><option>General plumbing / other</option>\n            </select>\n          </div>\n          <div class=\"ff\"><label for=\"suburb\">Suburb</label><input id=\"suburb\" type=\"text\" autocomplete=\"address-level2\" placeholder=\"e.g. Gungahlin\"></div>\n          <div class=\"ff\"><label for=\"detail\">Anything else? (optional)</label><textarea id=\"detail\" placeholder=\"A quick description helps us bring the right gear.\"></textarea></div>\n          <button class=\"btn btn-call\" type=\"button\" onclick=\"submitLead()\">Send &amp; get my call back</button>\n          <p class=\"q-fine\">Genuine emergency? Don't wait — <a id=\"formCall\" href=\"#\" style=\"color:var(--pipe);font-weight:700\">call us now</a>.</p>\n        </div>\n        <div class=\"q-success\" id=\"quoteSuccess\">\n          <div class=\"big\">Got it — sit tight. ✓</div>\n          <p style=\"margin-top:10px;color:var(--muted);font-weight:500\">A {{businessName}} plumber will call you on the number you gave us. If it's an emergency, please call {{phoneText}} so we can get moving now.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- FAQ -->\n  <section data-sec=\"faq\" class=\"section\">\n    <div class=\"wrap\">\n      <div class=\"section-head\" style=\"margin:0 auto;text-align:center\"><span class=\"eyebrow\">Good to know</span><h2>Quick answers.</h2></div>\n      <div class=\"faq\">\n        <details open><summary>Do you charge a call-out fee?</summary><p>We quote a fixed price for the job before we start, so you're never surprised. For genuine emergencies we'll always be straight with you about costs over the phone first.</p></details>\n        <details><summary>Can you really come same-day?</summary><p>For blocked drains, burst pipes and no-hot-water jobs we aim to be on site the same day, and we run a 24/7 line for emergencies across the ACT.</p></details>\n        <details><summary>Are you licensed and insured?</summary><p>Yes — fully licensed ACT plumbers and fully insured. Our licence number is on every invoice and we're happy to show it before any work begins.</p></details>\n      </div>\n    </div>\n  </section>\n\n</main>\n\n<footer class=\"site\" data-sec=\"footer\">\n  <div class=\"wrap\">\n    <div class=\"foot-grid\">\n      <div>\n        <a class=\"brand\" href=\"#top\"><span class=\"mark\">{{initial}}</span><span class=\"nm\" style=\"color:#fff\">{{businessName}}</span></a>\n        <p style=\"max-width:34ch\">Fast, fixed-price plumbing across Canberra and the ACT. Blocked drains, burst pipes, hot water and emergencies — done properly, first time.</p>\n      </div>\n      <div>\n        <h4>Call us</h4>\n        <a id=\"footPhone\" href=\"#\">{{phoneText}}</a>\n        <a href=\"mailto:{{email}}\">{{email}}</a>\n        <a href=\"#\">24/7 emergency line</a>\n      </div>\n      <div>\n        <h4>Services</h4>\n        <a href=\"#quote\">Blocked drains</a><a href=\"#quote\">Burst pipes</a><a href=\"#quote\">Hot water</a><a href=\"#quote\">Leak detection</a>\n      </div>\n    </div>\n    <p class=\"foot-legal\">{{businessName}} — ACT Plumbing Licence 0000000 (placeholder). ABN 00 000 000 000. Fully insured. Servicing Canberra &amp; the ACT, 7 days. © 2026 {{businessName}}.</p>\n  </div>\n</footer>\n\n<div class=\"mobile-call\"><a id=\"mobileCall\" href=\"#\">📞 Call now — {{phoneText}}</a></div>\n\n<script>\n/* ============================================================\n   ANALYTICS HOOKS — same contract as the broker template, so\n   both feed one events table in the platform.\n   ============================================================ */\nwindow.dataLayer = window.dataLayer || [];\nfunction trackEvent(name, props = {}){\n  const payload = { event:name, site:SITE_CONFIG.business, ts:Date.now(), ...props };\n  window.dataLayer.push(payload);\n  console.log(\"[track]\", payload);\n  fetch('/api/events', {\n    method:'POST',\n    headers:{'Content-Type':'application/json'},\n    body: JSON.stringify({ site:SITE_CONFIG.business, event:name, props:{ ...props, ts:Date.now() } }),\n    keepalive:true             // call_click is the money metric — fire it even as the dialer opens\n  }).catch(()=>{});\n}\n\n/* click-to-call: wire every tel link + log it (this is the money metric) */\n(function wirePhones(){\n  const tel = \"tel:\" + SITE_CONFIG.phone;\n  [\"emergCall\",\"navPhone\",\"headCall\",\"heroCall\",\"areaCall\",\"formCall\",\"footPhone\",\"mobileCall\"].forEach(id=>{\n    const el = document.getElementById(id); if(!el) return;\n    if(el.tagName===\"A\") el.href = tel;\n    el.addEventListener(\"click\",()=>trackEvent(\"call_click\",{location:id}));\n  });\n})();\n\n/* quote submit stub */\nasync function submitLead(){\n  const g = id => document.getElementById(id);\n  const data = { name:g('name').value.trim(), phone:g('phone').value.trim(), job:g('job').value,\n                 suburb:g('suburb').value.trim(), detail:g('detail').value.trim() };\n  if(!data.name || !data.phone){ alert(\"Please add your name and phone so we can call you back.\"); return; }\n  trackEvent(\"lead_submit\",{ job:data.job, suburb:data.suburb });\n  try {\n    const res = await fetch('/api/leads', {\n      method:'POST',\n      headers:{'Content-Type':'application/json'},\n      body: JSON.stringify({\n        site: SITE_CONFIG.business,\n        kind: \"trade\",\n        name: data.name,\n        email: null,\n        phone: data.phone,\n        details: { job:data.job, suburb:data.suburb, detail:data.detail }\n      })\n    });\n    if(!res.ok) console.error(\"Lead save failed:\", res.status, await res.text());\n  } catch(e){ console.error(\"Lead save error:\", e); }\n  // Always thank the customer so a backend hiccup never bounces a real lead.\n  document.getElementById(\"quoteForm\").style.display=\"none\";\n  document.getElementById(\"quoteSuccess\").classList.add(\"show\");\n}\n\ntrackEvent(\"page_view\",{ page:\"trade_landing\", trade:SITE_CONFIG.trade });\n</script>\n</body>\n</html>\n"}