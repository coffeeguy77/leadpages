{"name": "agency", "label": "Web studio homepage", "html": "<!doctype html><html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<title>{{STUDIO}} — Websites for local business</title>\n<meta name=\"description\" content=\"{{HERO_SUB}}\">\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\"><link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Archivo:wght@600;700;800;900&family=Inter:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap\" rel=\"stylesheet\">\n<style>\n:root{--ac:{{ACCENT}};--ink:{{INK}};--brand:{{BRAND}};--paper:#fbfaf7;--card:#fff;--line:#e9e6df;--soft:#6b7178;--ink-2:#222932}\n*{box-sizing:border-box}html{scroll-behavior:smooth}\nbody{margin:0;font-family:Inter,system-ui,sans-serif;color:var(--ink);background:var(--paper);line-height:1.55;-webkit-font-smoothing:antialiased}\nh1,h2,h3{font-family:Archivo,sans-serif;font-weight:900;letter-spacing:-.025em;margin:0;line-height:1.04}\na{color:inherit;text-decoration:none}\n.wrap{max-width:1120px;margin:0 auto;padding:0 24px}\n.mono{font-family:'Space Mono',monospace;font-size:12px;letter-spacing:.16em;text-transform:uppercase}\n.btn{display:inline-flex;align-items:center;gap:9px;font-family:Archivo;font-weight:800;font-size:15px;padding:14px 24px;border-radius:11px;background:var(--ac);color:#fff;border:2px solid var(--ac);cursor:pointer;transition:transform .12s,box-shadow .12s}\n.btn:hover{transform:translateY(-2px);box-shadow:0 14px 30px -12px color-mix(in srgb,var(--ac) 70%,#000)}\n.btn.ghost{background:transparent;border-color:currentColor}\n/* nav */\n.nav{position:sticky;top:0;z-index:20;background:color-mix(in srgb,var(--ink) 88%,transparent);backdrop-filter:blur(10px);border-bottom:1px solid rgba(255,255,255,.08)}\n.nav .wrap{display:flex;align-items:center;justify-content:space-between;height:68px}\n.ag-logo-img{max-height:38px;max-width:190px;display:block}\n.ag-logo-txt{font-family:Archivo;font-weight:900;font-size:21px;color:#fff;letter-spacing:-.02em}\n.nav .mono{color:rgba(255,255,255,.55)}\n.nav a.lk{color:#fff;font-family:Archivo;font-weight:700;font-size:14.5px}\n/* hero */\n.hero{background:radial-gradient(120% 120% at 82% -25%,color-mix(in srgb,var(--brand) 34%,var(--ink)),var(--ink) 62%);color:#fff;padding:76px 0 88px;position:relative;overflow:hidden}\n.hero:after{content:\"\";position:absolute;inset:0;background:radial-gradient(60% 50% at 18% 110%,color-mix(in srgb,var(--ac) 22%,transparent),transparent 70%);pointer-events:none}\n.hero .wrap{position:relative;z-index:1}\n.hero .eyebrow{color:var(--ac);margin-bottom:20px}\n.hero h1{font-size:clamp(40px,6.6vw,76px);max-width:15ch}\n.hero h1 .hl{position:relative;white-space:nowrap}\n.hero h1 .hl:before{content:\"\";position:absolute;left:-.06em;right:-.06em;bottom:.06em;height:.42em;background:var(--ac);opacity:.9;z-index:-1;transform:skewX(-9deg);border-radius:3px}\n.hero p.sub{color:#c9ced6;font-size:clamp(17px,2.1vw,20px);max-width:54ch;margin:22px 0 0}\n/* domain search — the signature */\n.dom{margin-top:36px;max-width:620px}\n.dom-l{color:#fff;font-family:Archivo;font-weight:800;font-size:15px;margin-bottom:10px;display:flex;align-items:center;gap:9px}\n.dom-l .dot{width:8px;height:8px;border-radius:50%;background:var(--ac);box-shadow:0 0 0 4px color-mix(in srgb,var(--ac) 30%,transparent)}\n.dom form{display:flex;gap:8px;background:#fff;border-radius:14px;padding:8px;box-shadow:0 24px 60px -28px rgba(0,0,0,.7)}\n.dom input{flex:1;border:0;background:transparent;font-size:17px;padding:12px 14px;font-family:Inter;color:var(--ink);outline:none;min-width:0}\n.dom .btn{white-space:nowrap;padding:13px 22px}\n.dom-h{color:#aeb6c0;font-family:'Space Mono',monospace;font-size:12px;margin-top:11px}\n.hero-cta{margin-top:26px;display:flex;gap:14px;flex-wrap:wrap;align-items:center}\n.hero-cta a.call{color:#fff;font-family:Archivo;font-weight:700;font-size:15px;border-bottom:2px solid var(--ac);padding-bottom:2px}\n/* section frame */\n.sec{padding:84px 0}\n.sec-head{max-width:60ch;margin-bottom:46px}\n.sec-head .eyebrow{color:var(--brand)}\n.sec-head h2{font-size:clamp(28px,4vw,42px);margin-top:14px}\n.sec-head p{color:var(--soft);font-size:18px;margin:14px 0 0}\n/* services */\n.svc-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:18px}\n.svc{background:var(--card);border:1px solid var(--line);border-radius:18px;padding:28px;position:relative;overflow:hidden}\n.svc:before{content:\"\";position:absolute;top:0;left:0;width:46px;height:4px;background:var(--ac);border-radius:0 0 4px 0}\n.svc .ic{font-size:28px;margin-bottom:16px;display:block}\n.svc h3{font-size:20px}\n.svc p{color:var(--soft);margin:9px 0 0;font-size:15px}\n/* work */\n.work{background:var(--ink);color:#fff}\n.work .sec-head .eyebrow{color:var(--ac)}.work .sec-head p{color:#b4bcc6}\n.work-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:18px}\n.ag-card{display:block;background:#fff;color:var(--ink);border-radius:16px;overflow:hidden;transition:transform .12s,box-shadow .15s}\n.ag-card:hover{transform:translateY(-4px);box-shadow:0 26px 50px -22px rgba(0,0,0,.6)}\n.ag-top{position:relative;height:118px;background:linear-gradient(135deg,var(--ac),var(--ink));display:flex;align-items:flex-end;justify-content:space-between;gap:8px;padding:13px}\n.ag-chip{width:50px;height:50px;border-radius:12px;background:#fff;display:flex;align-items:center;justify-content:center;overflow:hidden;box-shadow:0 8px 18px -8px rgba(0,0,0,.55);flex:0 0 auto}\n.ag-chip img{max-width:84%;max-height:84%;object-fit:contain}.ag-chip.mono{font-family:Archivo;font-weight:900;color:var(--ac);font-size:22px}\n.ag-trade{font-family:'Space Mono',monospace;font-size:11px;letter-spacing:.06em;text-transform:uppercase;color:#fff;background:rgba(0,0,0,.28);padding:5px 9px;border-radius:7px}\n.ag-lock{position:absolute;top:11px;right:11px;font-size:13px;background:rgba(0,0,0,.4);width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center}\n.ag-body{padding:16px 17px}.ag-name{font-family:Archivo;font-weight:800;font-size:18px}.ag-view{color:var(--ac);font-weight:700;font-size:14px;margin-top:7px}\n.ag-empty{color:#b4bcc6}\n/* about */\n.about-grid{display:grid;grid-template-columns:1.1fr .9fr;gap:48px;align-items:center}\n.about-copy h2{font-size:clamp(26px,3.6vw,38px)}\n.about-copy .eyebrow{color:var(--brand)}\n.about-copy p{color:var(--soft);font-size:17px;margin:16px 0 0}\n.about-img{border-radius:20px;overflow:hidden;border:1px solid var(--line);aspect-ratio:4/3;background:var(--ink)}\n.about-img img{width:100%;height:100%;object-fit:cover;display:block}\n/* contact */\n.contact{background:var(--ac);color:#fff;text-align:center}\n.contact h2{font-size:clamp(30px,4.4vw,50px)}\n.contact p{max-width:50ch;margin:16px auto 0;font-size:18px;opacity:.92}\n.contact .row{margin-top:30px;display:flex;gap:14px;justify-content:center;flex-wrap:wrap}\n.contact .btn{background:#fff;color:var(--ink);border-color:#fff}\n.contact .btn.ghost{background:transparent;color:#fff;border-color:rgba(255,255,255,.5)}\n/* foot */\n.foot{background:var(--ink);color:#9aa2ad;padding:30px 0;font-size:13px;text-align:center}\n@media(max-width:760px){.about-grid{grid-template-columns:1fr}.about-img{order:-1}.sec{padding:60px 0}.hero{padding:56px 0 64px}}\n@media(prefers-reduced-motion:reduce){*{transition:none!important;scroll-behavior:auto}}\n</style></head><body>\n<header class=\"nav\"><div class=\"wrap\">{{LOGO}}<a class=\"lk\" href=\"#contact\">Get in touch</a></div></header>\n<section class=\"hero\"><div class=\"wrap\">\n  <div class=\"eyebrow mono\">{{HERO_EYEBROW}}</div>\n  <h1>{{HERO_TITLE}}</h1>\n  <p class=\"sub\">{{HERO_SUB}}</p>\n  <div class=\"dom\">\n    <div class=\"dom-l\"><span class=\"dot\"></span>Start with your name</div>\n    <form method=\"get\" action=\"{{DOMAIN_ACTION}}\">\n      <input name=\"q\" type=\"text\" placeholder=\"yourbusiness.com.au\" aria-label=\"Search for a domain\" autocomplete=\"off\">\n      <button class=\"btn\" type=\"submit\">Search domains</button>\n    </form>\n    <div class=\"dom-h\">Find the perfect web address — we register and connect it for you.</div>\n  </div>\n  <div class=\"hero-cta\">{{HERO_CALL}}</div>\n</div></section>\n<section class=\"sec\"><div class=\"wrap\">\n  <div class=\"sec-head\"><div class=\"eyebrow mono\">What we build</div><h2>Websites that do real work</h2><p>Fast, mobile-first sites built to turn visitors into enquiries — not just look pretty.</p></div>\n  <div class=\"svc-grid\">{{SERVICES}}</div>\n</div></section>\n<section class=\"sec work\" id=\"work\"><div class=\"wrap\">\n  <div class=\"sec-head\"><div class=\"eyebrow mono\">Recent work</div><h2>A few we’ve built</h2><p>Tap any project to see it live.</p></div>\n  <div class=\"work-grid\">{{WORK}}</div>\n</div></section>\n<section class=\"sec\"><div class=\"wrap\"><div class=\"about-grid\">\n  <div class=\"about-copy\"><div class=\"eyebrow mono\">{{ABOUT_EYEBROW}}</div><h2>{{ABOUT_HEADING}}</h2><p>{{ABOUT_BODY}}</p></div>\n  {{ABOUT_IMG}}\n</div></div></section>\n<section class=\"sec contact\" id=\"contact\"><div class=\"wrap\">\n  <h2>{{CONTACT_HEADING}}</h2><p>{{CONTACT_SUB}}</p>\n  <div class=\"row\">{{CONTACT_BTNS}}</div>\n</div></section>\n<footer class=\"foot\"><div class=\"wrap\">{{STUDIO}} · Websites for local business · &copy; {{YEAR}}</div></footer>\n</body></html>"}